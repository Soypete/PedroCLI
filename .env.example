# =============================================================================
# PedroCLI Environment Variables
# =============================================================================
# Copy to .env and fill in your values.
# Use `op run --env-file=.env -- ./pedrocli-http-server` for 1Password injection.

# --- Database (Supabase) ---
# Supabase connection string (preferred). Get from Supabase Dashboard → Settings → Database.
# Use the "Connection string" (URI) format. Transaction mode pooler is recommended.
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-us-west-1.pooler.supabase.com:6543/postgres?sslmode=require

# Or use 1Password reference:
# DATABASE_URL=op://pedro/supabase_database_url/credential

# Or individual components (fallback if DATABASE_URL is not set)
# DB_HOST=aws-0-us-west-1.pooler.supabase.com
# DB_PORT=6543
# DB_NAME=postgres
# DB_USER=postgres.<project-ref>
# DB_PASSWORD=<your-supabase-password>
# DB_SSLMODE=require

# --- Test Database ---
# For local testing, use a local Postgres instance
TEST_DATABASE_URL=postgres://pedrocli_test:pedrocli_test@localhost:5433/pedrocli_test?sslmode=disable

# --- Notion API (for blog tools) ---
# Use 1Password reference: op://pedro/notion_api_key/credential
NOTION_TOKEN=op://pedro/notion_api_key/credential

# --- Cal.com API (for scheduling) ---
# Use 1Password reference: op://pedro/cal.com/credential
CAL_API_KEY=op://pedro/cal.com/credential
